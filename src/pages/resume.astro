---
import Layout from '@/layouts/Layout.astro'
import ExperienceItem from '@/components/ExperienceItem.astro'
import EducationItem from '@/components/EducationItem.astro'
import { resume } from '@/data/resume'
---

<Layout title="Resume — Carson Underwood">
  <div class="rounded-xl border border-slate-700/50 bg-slate-800 p-8 shadow-xl">
    <!-- Header -->
    <div class="mb-6 border-b border-slate-700/50 pb-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-slate-100">{resume.name}</h1>
          <p class="mt-1 font-mono text-sm text-slate-400">
            {resume.email}
          </p>
        </div>
        {
          resume.pdfPath && (
            <a
              href={resume.pdfPath}
              download
              class="inline-flex items-center gap-2 rounded-lg bg-cyan-500/10 px-4 py-2 text-sm font-medium text-cyan-400 ring-1 ring-cyan-500/30 hover:bg-cyan-500/20"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"
                  clip-rule="evenodd"
                />
              </svg>
              Download PDF
            </a>
          )
        }
      </div>
    </div>

    <!-- Summary -->
    {
      resume.summary && (
        <section class="mb-6">
          <h2 class="mb-3 flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-cyan-400">
            <span class="h-px flex-1 bg-cyan-500/20" />
            Summary
            <span class="h-px flex-1 bg-cyan-500/20" />
          </h2>
          <p class="text-sm leading-relaxed text-slate-300">{resume.summary}</p>
        </section>
      )
    }

    <!-- Experience -->
    {
      resume.experience.length > 0 && (
        <section class="mb-6">
          <h2 class="mb-4 flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-cyan-400">
            <span class="h-px flex-1 bg-cyan-500/20" />
            Experience
            <span class="h-px flex-1 bg-cyan-500/20" />
          </h2>
          <div class="space-y-6">
            {resume.experience.map((exp) => (
              <ExperienceItem experience={exp} />
            ))}
          </div>
        </section>
      )
    }

    <!-- Education -->
    {
      resume.education.length > 0 && (
        <section class="mb-6">
          <h2 class="mb-4 flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-cyan-400">
            <span class="h-px flex-1 bg-cyan-500/20" />
            Education
            <span class="h-px flex-1 bg-cyan-500/20" />
          </h2>
          {resume.education.map((edu) => (
            <EducationItem education={edu} />
          ))}
        </section>
      )
    }

    <!-- Skills -->
    {
      resume.skills.length > 0 && (
        <section>
          <h2 class="mb-3 flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-cyan-400">
            <span class="h-px flex-1 bg-cyan-500/20" />
            Skills
            <span class="h-px flex-1 bg-cyan-500/20" />
          </h2>
          <div class="flex flex-wrap gap-2">
            {resume.skills.map((skill) => (
              <span class="rounded-md bg-slate-700/60 px-3 py-1 font-mono text-xs text-cyan-300 ring-1 ring-slate-600/50">
                {skill}
              </span>
            ))}
          </div>
        </section>
      )
    }
  </div>
</Layout>
